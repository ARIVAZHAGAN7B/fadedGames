{
  "name": "bingo",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "client": "npm run dev --workspace client",
    "server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server",
    "security-smoke": "node server/security.test.js"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
